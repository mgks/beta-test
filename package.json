{
  "name": "docmd-beta-test",
  "version": "0.0.0",
  "private": true,
  "description": "docmd pre-release staging site. CI builds fresh tarballs from the docmd monorepo and deploys to GitHub Pages for real-environment testing before tagging a release.",
  "scripts": {
    "build": "docmd build",
    "dev": "docmd dev",
    "preview": "npx serve site"
  },
  "dependencies": {
    "@docmd/api": "file:./local-tars/docmd-api.tgz",
    "@docmd/core": "file:./local-tars/docmd-core.tgz",
    "@docmd/deployer": "file:./local-tars/docmd-deployer.tgz",
    "@docmd/engine-js": "file:./local-tars/docmd-engine-js.tgz",
    "@docmd/engine-rust-binaries": "file:./local-tars/docmd-engine-rust-binaries.tgz",
    "@docmd/engine-rust": "file:./local-tars/docmd-engine-rust.tgz",
    "@docmd/live": "file:./local-tars/docmd-live.tgz",
    "@docmd/parser": "file:./local-tars/docmd-parser.tgz",
    "@docmd/themes": "file:./local-tars/docmd-themes.tgz",
    "@docmd/tui": "file:./local-tars/docmd-tui.tgz",
    "@docmd/ui": "file:./local-tars/docmd-ui.tgz",
    "@docmd/utils": "file:./local-tars/docmd-utils.tgz"
  },
  "allowScripts": {
    "@docmd/engine-rust": true,
    "@docmd/engine-rust-binaries": true,
    "esbuild": true,
    "onnxruntime-node": true,
    "protobufjs": true
  }
}
